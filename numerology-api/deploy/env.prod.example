# =============================================================
# Production environment template — copy to .env.prod and fill
# NEVER commit .env.prod to version control
# =============================================================

# --- Postgres (used by both db service and api service) ---
POSTGRES_DB=numerology
POSTGRES_USER=numerology
POSTGRES_PASSWORD=__CHANGE_ME__

# Async DSN — host must match docker-compose service name "db"
DATABASE_URL=postgresql+asyncpg://numerology:__CHANGE_ME__@db:5432/numerology

# --- JWT ---
# Generate: python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET=__GENERATE_64_BYTES__
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Google OAuth ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Facebook OAuth ---
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# --- CORS / Origins ---
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://nhansinhquan.vn,https://cms.nhansinhquan.vn

# --- Frontend & redirect base ---
FRONTEND_URL=https://nhansinhquan.vn
OAUTH_REDIRECT_BASE=https://cms.nhansinhquan.vn

# --- File storage paths inside container ---
MEDIA_ROOT=/code/media
STATIC_ROOT=/code/static

# --- App mode ---
DEBUG=false
ENVIRONMENT=production

# --- Cloudflare Turnstile ---
# Get from: Cloudflare Dashboard → Turnstile → <site> → Secret Key
# Leave empty to disable CAPTCHA verification (dev/CI only)
TURNSTILE_SECRET_KEY=

# --- Rate limiting ---
# Set to false only in test environments to avoid flaky tests
RATE_LIMIT_ENABLED=true
# Proxy trust mode: "cloudflare" (default) → only trust CF-Connecting-IP header.
# Switch to "direct" only if traffic hits nginx without Cloudflare proxy (e.g. DNS-only mode).
TRUSTED_PROXY_MODE=cloudflare

# --- Observability ---
# Get DSN from https://sentry.io → Project Settings → Client Keys
# Leave empty to disable Sentry (local dev / staging without quota)
SENTRY_DSN=

# --- SePay reconcile ---
# Hours to look back when matching pending orders against SePay transactions
RECONCILE_WINDOW_HOURS=24
