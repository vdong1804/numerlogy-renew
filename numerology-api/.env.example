# =============================================================================
# Database
# =============================================================================
DATABASE_URL=postgresql+asyncpg://numerology:numerology@db:5432/numerology
POSTGRES_USER=numerology
POSTGRES_PASSWORD=numerology
POSTGRES_DB=numerology

# =============================================================================
# JWT
# =============================================================================
JWT_SECRET=change-me-to-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# =============================================================================
# OAuth (legacy — kept for compat)
# =============================================================================
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret

# =============================================================================
# App
# =============================================================================
DEBUG=false
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# Frontend / OAuth redirect URLs
FRONTEND_URL=http://localhost:3000
OAUTH_REDIRECT_BASE=http://localhost:8000

# Static / media
MEDIA_ROOT=./media
MEDIA_URL=/media
STATIC_ROOT=./static

# =============================================================================
# Password reset
# =============================================================================
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30
PASSWORD_RESET_URL_PATH=/reset-password

# =============================================================================
# SMTP — transactional email (Phase 05)
# =============================================================================
# Gmail SMTP ví dụ:
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=youraddress@gmail.com
#   SMTP_PASSWORD=<app-password>  # bật 2FA + tạo App Password, KHÔNG dùng mật khẩu chính
#   SMTP_USE_TLS=true
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@nhansinhquan.vn
SMTP_USE_TLS=true

# =============================================================================
# SePay webhook (Phase 02)
# =============================================================================
# API key SePay gửi kèm header `Authorization: Apikey <key>`
SEPAY_API_KEY=
# Sai số amount cho phép khi đối chiếu (đơn vị VND)
SEPAY_AMOUNT_TOLERANCE_VND=1000
# IP allowlist cho webhook (CSV). Để trống = cho phép tất cả.
SEPAY_WEBHOOK_IP_WHITELIST=

# =============================================================================
# Bank info (hiển thị trên trang checkout + dựng VietQR)
# =============================================================================
BANK_ACCOUNT_NUMBER=
BANK_ACCOUNT_HOLDER=
# Mã ngân hàng (VCB / MB / ACB / TCB / ...). Xem danh sách của SePay.
BANK_CODE=
BANK_NAME=

# =============================================================================
# Environment (Phase 02)
# Dùng cho Sentry tag + startup assertion (production assert TURNSTILE_SECRET_KEY)
# Values: development | staging | production
# =============================================================================
ENVIRONMENT=development

# =============================================================================
# Sentry — error tracking (Phase 02)
# Signup free: https://sentry.io → create FastAPI project → copy DSN
# Để trống = skip init (dev/CI safe)
# =============================================================================
SENTRY_DSN=

# =============================================================================
# Reconcile-SePay cron (Phase 02)
# Pull transactions trong N giờ gần nhất để match orders pending
# =============================================================================
RECONCILE_WINDOW_HOURS=24

# =============================================================================
# Cloudflare Turnstile CAPTCHA (Phase 03)
# Backend secret để verify token từ frontend
# Signup: https://dash.cloudflare.com → Turnstile → create site → copy Secret Key
# Để trống trong dev = skip verify (KHÔNG được trống trong production — startup raise)
# =============================================================================
TURNSTILE_SECRET_KEY=

# =============================================================================
# Rate limiting (Phase 03)
# In-memory slowapi: /auth/login 5/min, /register 3/min, /forgot-password 3/min, /webhooks/sepay 100/min
# Disable trong test env để tránh flaky tests
# =============================================================================
RATE_LIMIT_ENABLED=true

# =============================================================================
# Trusted proxy mode (Phase 03)
# cloudflare: chỉ trust header CF-Connecting-IP (khuyến nghị prod sau Cloudflare proxy)
# direct: dùng request.client.host (khi traffic đi thẳng nginx, không qua Cloudflare)
# =============================================================================
TRUSTED_PROXY_MODE=cloudflare

# =============================================================================
# Gemini — embeddings only (text-embedding-004, 768-dim)
# Get API key from https://aistudio.google.com/apikey
# Empty in tests/CI (mocked); REQUIRED in production for RAG embeddings.
# =============================================================================
GEMINI_API_KEY=
EMBEDDING_MODEL=text-embedding-004
EMBEDDING_BATCH_SIZE=100
CHUNK_MAX_TOKENS=500
CHUNK_OVERLAP_TOKENS=50

# =============================================================================
# DeepSeek — chat generation (OpenAI-compatible API)
# Get API key from https://platform.deepseek.com/api_keys
# REQUIRED in production for chat. Single model serves flash + pro tiers.
# =============================================================================
DEEPSEEK_API_KEY=sk-4d972d69263a4ad691f858ebcbad33ab
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_CHAT_MODEL=deepseek-chat

