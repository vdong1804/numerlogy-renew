# Deps are installed fresh in the `deps` stage — never copy the host copy
# (Windows-built binaries would break the Alpine image).
node_modules

# Build artifacts (regenerated by `yarn build`)
.next
out

# VCS / local / secrets — must not leak into the image
.git
.gitignore
.env
.env.*
*.local

# Tooling / tests not needed for the production build
cypress
coverage
__mocks__
.vscode
.idea
npm-debug.log*
yarn-error.log*
