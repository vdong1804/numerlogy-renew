# =============================================================================
# App host
# =============================================================================
HOSTNAME=localhost
PORT=8000

# Backend API base used by the browser (must be reachable from the client).
API_ENDPOINT=http://$HOSTNAME:$PORT
NEXT_PUBLIC_API_BASE=http://localhost:8000
NODE_ENV=local

# =============================================================================
# Site URL (Phase 01)
# Dùng cho canonical URL, sitemap, OG meta, JSON-LD Organization
# Phải khớp domain prod (không trailing slash)
# =============================================================================
NEXT_PUBLIC_SITE_URL=https://nhansinhquan.vn

# =============================================================================
# Analytics — fire SAU khi cookie consent accept (Phase 01)
# Để trống = không render script tag (compliance NĐ 13/2023)
# =============================================================================
# Google Analytics 4 — Measurement ID format G-XXXXXXXXXX
# Lấy tại: https://analytics.google.com → Admin → Data Streams → Web
NEXT_PUBLIC_GA4_ID=

# Meta (Facebook) Pixel ID — chỉ digits
# Lấy tại: https://business.facebook.com → Events Manager → Data Sources → Pixel
NEXT_PUBLIC_FB_PIXEL_ID=

# =============================================================================
# Cloudflare Turnstile CAPTCHA (Phase 03 — register + forgot-password forms)
# Get site key from: https://dash.cloudflare.com/?to=/:account/turnstile
# Dev: để trống → widget auto-pass sau 100ms (guarded by NODE_ENV !== 'production')
# Prod: BẮT BUỘC set, nếu không widget hiện error UI và block submit
# =============================================================================
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# =============================================================================
# Sentry error monitoring (Phase 02 fixed)
# Signup free: https://sentry.io → create Next.js project → copy DSN
# =============================================================================
# Client-side DSN MUST use NEXT_PUBLIC_ prefix to be exposed to the browser bundle
NEXT_PUBLIC_SENTRY_DSN=
# Server/edge DSN (not exposed to browser) — có thể trùng giá trị với NEXT_PUBLIC_SENTRY_DSN
SENTRY_DSN=
