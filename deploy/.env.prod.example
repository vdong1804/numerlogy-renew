# =============================================================================
# Unified production env — copy to .env.prod and fill secrets.
# NEVER commit .env.prod to version control.
#
#   cp .env.prod.example .env.prod
#
# Two consumers:
#   - api + db services read this file at RUNTIME (env_file in compose).
#   - frontend reads NEXT_PUBLIC_* at BUILD time (passed as build args by
#     deploy.sh / docker compose). They are inlined into the JS bundle.
# =============================================================================

# -----------------------------------------------------------------------------
# Postgres (shared by db + api)
# -----------------------------------------------------------------------------
POSTGRES_DB=numerology
POSTGRES_USER=numerology
POSTGRES_PASSWORD=__CHANGE_ME__

# Async DSN — host must equal the compose service name "db"
DATABASE_URL=postgresql+asyncpg://numerology:__CHANGE_ME__@db:5432/numerology

# -----------------------------------------------------------------------------
# JWT — generate: python -c "import secrets; print(secrets.token_hex(64))"
# -----------------------------------------------------------------------------
JWT_SECRET=__GENERATE_64_BYTES__
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# -----------------------------------------------------------------------------
# OAuth
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# -----------------------------------------------------------------------------
# CORS / origins / redirects
# -----------------------------------------------------------------------------
ALLOWED_ORIGINS=https://nhansinhquan.vn,https://www.nhansinhquan.vn,https://cms.nhansinhquan.vn
FRONTEND_URL=https://nhansinhquan.vn
OAUTH_REDIRECT_BASE=https://api.nhansinhquan.vn

# -----------------------------------------------------------------------------
# File storage paths inside the api container
# -----------------------------------------------------------------------------
# Must match the docker-compose bind-mount targets (image WORKDIR is /app).
MEDIA_ROOT=/app/media
MEDIA_URL=/media
STATIC_ROOT=/app/static

# -----------------------------------------------------------------------------
# App mode
# -----------------------------------------------------------------------------
DEBUG=false
ENVIRONMENT=production

# -----------------------------------------------------------------------------
# Email (SMTP) — transactional mail
# -----------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@nhansinhquan.vn
SMTP_USE_TLS=true

# -----------------------------------------------------------------------------
# Password reset
# -----------------------------------------------------------------------------
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30
PASSWORD_RESET_URL_PATH=/reset-password

# -----------------------------------------------------------------------------
# SePay payment webhook + bank display
# -----------------------------------------------------------------------------
SEPAY_API_KEY=
SEPAY_AMOUNT_TOLERANCE_VND=1000
SEPAY_WEBHOOK_IP_WHITELIST=
BANK_ACCOUNT_NUMBER=
BANK_ACCOUNT_HOLDER=
BANK_CODE=
BANK_NAME=
RECONCILE_WINDOW_HOURS=24

# -----------------------------------------------------------------------------
# Security — Turnstile CAPTCHA, rate limiting, proxy trust
# Backend secret + (separately) the public site key below for the frontend.
# -----------------------------------------------------------------------------
TURNSTILE_SECRET_KEY=
RATE_LIMIT_ENABLED=true
# "direct" = traffic hits nginx without Cloudflare proxy (recommended here,
# since this nginx is the public edge). Use "cloudflare" only behind CF proxy.
TRUSTED_PROXY_MODE=direct

# -----------------------------------------------------------------------------
# Observability
# -----------------------------------------------------------------------------
SENTRY_DSN=

# -----------------------------------------------------------------------------
# AI — Gemini embeddings + DeepSeek chat (required in production)
# -----------------------------------------------------------------------------
GEMINI_API_KEY=
EMBEDDING_MODEL=text-embedding-004
EMBEDDING_BATCH_SIZE=100
CHUNK_MAX_TOKENS=500
CHUNK_OVERLAP_TOKENS=50

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_CHAT_MODEL=deepseek-chat

# =============================================================================
# FRONTEND BUILD ARGS (NEXT_PUBLIC_*) — inlined into the JS bundle at build.
# Changing any of these requires a frontend rebuild (deploy.sh handles it).
# =============================================================================
NEXT_PUBLIC_API_BASE=https://api.nhansinhquan.vn
NEXT_PUBLIC_SITE_URL=https://nhansinhquan.vn
NEXT_PUBLIC_GA4_ID=
NEXT_PUBLIC_FB_PIXEL_ID=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
NEXT_PUBLIC_SENTRY_DSN=
